# ============================================================
# SRCC FAQ Bot - Environment Variables
# このファイルを .env.local にコピーして値を設定してください
# ============================================================

# Anthropic (Claude) - 回答生成・Entity抽出
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# OpenAI - text-embedding-3-small (埋め込みベクトル生成)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Pinecone - ベクトルDB
PINECONE_API_KEY=xxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=srcc-faq
PINECONE_ENVIRONMENT=us-east-1-aws  # Serverless の場合は不要

# Cohere - Re-ranking
COHERE_API_KEY=xxxxxxxxxxxxxxxx

# Upstash Redis - セッション管理 (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://xxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# App Settings
APP_ENV=development           # development | production
LOG_LEVEL=INFO
MAX_SEARCH_RESULTS=10         # Hybrid Search の初期取得件数
RERANK_TOP_N=3                # Re-rank後に最終的に使う件数
SESSION_TTL_SECONDS=1800      # Redis セッション有効期限 (30分)
MAX_CONVERSATION_TURNS=5      # 保持する会話ターン数
